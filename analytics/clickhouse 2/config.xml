<?xml version="1.0"?>
<clickhouse>
    <!-- ClickHouse configuration for Coinet Analytics -->
    
    <!-- Logging -->
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>1000M</size>
        <count>3</count>
    </logger>

    <!-- HTTP interface -->
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    
    <!-- Security -->
    <max_connections>4096</max_connections>
    <keep_alive_timeout>3</keep_alive_timeout>
    <max_concurrent_queries>100</max_concurrent_queries>
    <uncompressed_cache_size>8589934592</uncompressed_cache_size>
    <mark_cache_size>5368709120</mark_cache_size>

    <!-- Analytics optimizations -->
    <merge_tree>
        <max_suspicious_broken_parts>5</max_suspicious_broken_parts>
        <parts_to_delay_insert>150</parts_to_delay_insert>
        <parts_to_throw_insert>300</parts_to_throw_insert>
        <max_delay_to_insert>1</max_delay_to_insert>
    </merge_tree>

    <!-- Memory usage -->
    <max_memory_usage>10000000000</max_memory_usage>
    <max_bytes_before_external_group_by>8000000000</max_bytes_before_external_group_by>
    
    <!-- Networking -->
    <listen_host>::</listen_host>
    
    <!-- Profiles for different use cases -->
    <profiles>
        <default>
            <max_memory_usage>10000000000</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>random</load_balancing>
        </default>
        
        <analytics>
            <max_memory_usage>20000000000</max_memory_usage>
            <max_execution_time>300</max_execution_time>
            <max_query_size>1000000000</max_query_size>
        </analytics>
        
        <realtime>
            <max_memory_usage>5000000000</max_memory_usage>
            <max_execution_time>10</max_execution_time>
            <priority>1</priority>
        </realtime>
    </profiles>

    <!-- Users -->
    <users>
        <default>
            <password></password>
            <networks incl="networks.xml" />
            <profile>default</profile>
            <quota>default</quota>
        </default>
        
        <coinet_analytics>
            <password>clickhouse_password_2024</password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>analytics</profile>
            <quota>default</quota>
            <databases>
                <database>coinet_analytics</database>
            </databases>
        </coinet_analytics>
    </users>

    <!-- Quotas -->
    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
