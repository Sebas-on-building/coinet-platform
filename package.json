{
  "name": "coinet",
  "version": "1.0.0",
  "description": "Coinet - AI-powered anomaly detection and trading system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "next dev --webpack",
    "dev:all": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "prisma:gen:root": "cd apps/coinet-platform && npx prisma generate",
    "prisma:migrate:root": "cd apps/coinet-platform && npx prisma migrate deploy",
    "benchmark": "cd services/market-prices && npm run benchmark",
    "benchmark:quick": "cd services/market-prices && npm run benchmark:quick",
    "benchmark:compare": "cd services/market-prices && npm run benchmark:compare",
    "train:fallback": "cd services/market-prices && npm run train:fallback"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.30.0",
    "@clerk/nextjs": "^6.36.5",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.91.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.462.0",
    "next": "^16.1.1",
    "next-themes": "^0.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0"
  }
}
