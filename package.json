{
  "name": "coinet",
  "version": "1.0.0",
  "description": "Coinet - AI-powered anomaly detection and trading system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --webpack",
    "build:turbo": "turbo build",
    "start": "next start",
    "dev": "next dev",
    "dev:all": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "check:backend": "pnpm --dir apps/coinet-platform typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "prisma:gen:root": "cd apps/coinet-platform && npx prisma generate",
    "prisma:migrate:root": "cd apps/coinet-platform && npx prisma migrate deploy",
    "prisma:platform:push": "pnpm --filter coinet-platform db:push",
    "prisma:platform:generate": "pnpm --filter coinet-platform db:generate",
    "benchmark": "cd services/market-prices && npm run benchmark",
    "benchmark:quick": "cd services/market-prices && npm run benchmark:quick",
    "benchmark:compare": "cd services/market-prices && npm run benchmark:compare",
    "train:fallback": "cd services/market-prices && npm run train:fallback"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": "20.x",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.31.0",
    "@clerk/nextjs": "^6.36.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.38.0",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.91.2",
    "apexcharts": "^5.3.6",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "bad-words": "^4.0.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^10.18.0",
    "franc-min": "^6.2.0",
    "fuse.js": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsep": "^1.4.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^5.1.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.462.0",
    "next": "^16.1.1",
    "next-themes": "^0.3.0",
    "node-cache": "^5.1.2",
    "openai": "^6.17.0",
    "pg": "^8.17.2",
    "react": "^19.2.3",
    "react-apexcharts": "^1.9.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-resizable": "^3.1.3",
    "react-rnd": "^10.5.2",
    "react-window": "^2.2.5",
    "recharts": "^3.7.0",
    "rss-parser": "^3.13.0",
    "sentiment": "^5.0.2",
    "sentiment-fr": "^1.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
