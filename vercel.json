{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/client-web && npm run build",
  "outputDirectory": "apps/client-web/dist",
  "installCommand": "cd apps/client-web && npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
