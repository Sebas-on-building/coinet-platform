{
  "name": "@coinet/ingest-service",
  "version": "1.0.0",
  "description": "Real-time crypto data ingestion and processing service",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.production.js",
    "start:dev": "tsx watch src/index.production.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.production.json",
    "build:all": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "docker:build": "docker build -f Dockerfile.production -t coinet/ingest-service:v1.0.0 .",
    "docker:run": "docker run -p 8001:8001 coinet/ingest-service:v1.0.0"
  },
  "keywords": [
    "coinet",
    "crypto",
    "blockchain",
    "data",
    "ingestion",
    "market-data",
    "binance",
    "kafka",
    "streaming",
    "real-time"
  ],
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^8.0.3",
    "bullmq": "^5.58.2",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.18.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.7",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.1.4",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
