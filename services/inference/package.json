{
  "name": "@coinet-ai/inference-service",
  "version": "1.0.0",
  "description": "LLM orchestration service for AI inference",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t coinet-ai/inference-service .",
    "deploy": "kubectl apply -f k8s/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "fastify": "^4.24.3",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^4.15.4",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "mongoose": "^8.0.3",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "pino": "^8.16.2",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "openai": "^4.24.1",
    "@anthropic-ai/sdk": "^0.13.1",
    "@google/generative-ai": "^0.2.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/node": "20.19.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/lodash": "^4.14.202",
    "tsx": "^4.6.2",
    "typescript": "^5.5.0",
    "tsc-alias": "^1.8.8",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16"
  }
}