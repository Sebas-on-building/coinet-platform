{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "noEmit": false
  },
  "include": [
    "src/index.ts",
    "src/standalone.ts",
    "src/swagger.ts",
    "src/jwt-rotation.ts",
    "src/prometheus-metrics.ts",
    "src/sentry-config.ts",
    "src/kafka-events.ts",
    "src/analytics-sinks.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/controllers/**",
    "src/middleware/**"
  ]
}