generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  pluginId  String
  type      String   // install, view, click, etc.
  userId    String?
  meta      Json?
  createdAt DateTime @default(now())
} 