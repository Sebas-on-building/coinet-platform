{
  "name": "coinet-testing-validation-framework",
  "version": "1.0.0",
  "description": "World-class comprehensive testing and validation framework for Coinet crypto alerts",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist logs",
    "docker:build": "docker build -t coinet-testing-validation .",
    "docker:run": "docker run -p 5000:5000 coinet-testing-validation"
  },
  "keywords": [
    "crypto",
    "trading",
    "alerts",
    "testing",
    "validation",
    "backtesting",
    "ab-testing",
    "shadow-mode",
    "feedback",
    "compliance"
  ],
  "author": "Coinet Platform",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "events": "^3.3.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.5",
    "@types/node": "^20.10.5",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coinet/platform"
  },
  "bugs": {
    "url": "https://github.com/coinet/platform/issues"
  },
  "homepage": "https://github.com/coinet/platform"
}
