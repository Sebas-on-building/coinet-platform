{
  "name": "@coinet/ai-data-feeder",
  "version": "1.0.0",
  "description": "24/7 AI data feeder service - continuously feeds Coinet AI with market data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
