    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "axios": "^1.6.2",
    "bottleneck": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2"
  }
}
