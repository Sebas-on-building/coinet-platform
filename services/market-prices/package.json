  "description": "Market Prices Service with CoinGecko and CoinMarketCap integration - 100% Complete",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
