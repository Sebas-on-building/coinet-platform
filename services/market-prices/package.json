{
  "name": "@coinet/market-prices",
  "version": "1.0.0",
  "description": "Production-ready market data integration with CoinGecko (primary) and CoinMarketCap (secondary) with WebSocket support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:defi": "vitest run src/tests/defillama.test.ts",
    "test:unified": "vitest run src/tests/unified-market-data.test.ts",
    "test:analytics": "vitest run src/tests/market-analytics.test.ts",
    "test:streamer": "vitest run src/tests/market-data-streamer.test.ts",
    "test:cryptopanic": "vitest run src/tests/cryptopanic.test.ts",
    "test:integration": "vitest run src/tests/*.test.ts",
    "example:cryptopanic": "ts-node src/examples/cryptopanic-integration.example.ts",
    "benchmark": "ts-node benchmarks/standalone-benchmark.ts",
    "benchmark:quick": "ts-node benchmarks/standalone-benchmark.ts --quick",
    "benchmark:compare": "ts-node benchmarks/competitor-comparison.ts",
    "benchmark:full": "ts-node benchmarks/free-tier-benchmark.ts",
    "benchmark:defi": "ts-node benchmarks/defi-benchmark.ts",
    "test:defi-features": "ts-node scripts/test-defi-features.ts",
    "test:health": "ts-node scripts/test-health.ts",
    "train:fallback": "ts-node benchmarks/train-fallback-model.ts",
    "load-test": "ts-node benchmarks/load-test.ts",
    "load-test:stress": "ts-node benchmarks/load-test.ts --stress",
    "report": "ts-node benchmarks/generate-report.ts",
    "security:rotate-keys": "ts-node scripts/rotate-keys.ts",
    "cache:clear": "ts-node scripts/clear-cache.ts",
    "alerts:status": "ts-node scripts/alert-status.ts",
    "lint": "eslint src/**/*.ts",
    "watch": "tsc --watch",
    "test:unlocks": "ts-node scripts/test-token-unlocks.ts",
    "test:unlocks:e2e": "ts-node scripts/test-token-unlocks.ts",
    "test:ml": "ts-node scripts/test-ml-pipeline.ts",
    "test:ml:accuracy": "ts-node scripts/test-ml-pipeline.ts --accuracy",
    "train:ml": "ts-node scripts/train-ml-model.ts",
    "railway:health": "ts-node scripts/check-railway-health.ts",
    "railway:monitor": "bash scripts/monitor-railway-deployment.sh",
    "test:realtime": "ts-node scripts/test-realtime-systems.ts",
    "test:realtime:full": "ts-node scripts/test-realtime-systems.ts --full",
    "test:comprehensive": "vitest run src/tests/token-unlocks-comprehensive.test.ts",
    "benchmark:accuracy": "ts-node benchmarks/competitor-accuracy-benchmark.ts",
    "reliability:quick": "ts-node scripts/reliability-test-24h.ts --quick",
    "reliability:1h": "ts-node scripts/reliability-test-24h.ts --1h",
    "reliability:4h": "ts-node scripts/reliability-test-24h.ts --4h",
    "reliability:24h": "ts-node scripts/reliability-test-24h.ts",
    "simulate:50k": "ts-node scripts/50k-user-simulation.ts",
    "simulate:scaling": "ts-node scripts/50k-user-simulation.ts --scaling",
    "simulate:optimized": "ts-node scripts/50k-user-simulation.ts --optimized",
    "test:fusion": "ts-node scripts/test-fusion-api.ts",
    "test:phase4-5": "ts-node scripts/test-phase-4-5.ts",
    "benchmark:human": "ts-node scripts/test-phase-4-5.ts",
    "dashboard": "ts-node scripts/run-dashboard.ts",
    "test:liquidity": "ts-node scripts/test-liquidity-analyzer.ts",
    "benchmark:1000x": "ts-node benchmarks/real-1000x-proof.ts",
    "benchmark:1000x:sustained": "ts-node benchmarks/real-1000x-proof.ts --sustained",
    "test:production:24h": "ts-node scripts/24h-production-test.ts",
    "test:production:quick": "ts-node scripts/24h-production-test.ts --quick",
    "test:real-api": "ts-node benchmarks/real-api-load-test.ts",
    "test:real-api:long": "ts-node benchmarks/real-api-load-test.ts --long",
    "test:real-api:quick": "ts-node benchmarks/real-api-load-test.ts --quick",
    "train:ml:real": "ts-node src/intelligence/ml/real-training-pipeline.ts",
    "validate:all": "npm run benchmark:1000x && npm run test:real-api:quick && npm run test:production:quick",
    "test:real:1000x": "ts-node benchmarks/real-1000x-load-test.ts",
    "test:real:1000x:quick": "ts-node benchmarks/real-1000x-load-test.ts quick",
    "test:real:1000x:full": "ts-node benchmarks/real-1000x-load-test.ts full",
    "test:real:1000x:sustained": "ts-node benchmarks/real-1000x-load-test.ts sustained",
    "test:24h": "ts-node benchmarks/24h-production-runner.ts",
    "test:24h:quick": "ts-node benchmarks/24h-production-runner.ts quick",
    "test:24h:full": "ts-node benchmarks/24h-production-runner.ts full",
    "divine:validate": "npm run test:real:1000x:quick && npm run test:24h:quick"
  },
  "keywords": [
    "cryptocurrency",
    "market-data",
    "coingecko",
    "coinmarketcap",
    "websocket",
    "real-time"
  ],
  "author": "Coinet",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-node": "^4.15.0",
    "axios": "^1.6.2",
    "axios-retry": "^4.0.0",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.1.2",
    "dotenv": "^16.3.1",
    "ethers": "^6.15.0",
    "eventemitter3": "^5.0.1",
    "express": "^4.21.2",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "rxjs": "^7.8.2",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
