# Environment
NODE_ENV=development # development | staging | production

# CoinGecko Configuration
# Development/Staging Key (Demo tier - 30 calls/min)
COINGECKO_API_KEY=your_coingecko_dev_api_key_here
# Production Key (Paid tier - 500-1000 calls/min)
COINGECKO_API_KEY_PROD=your_coingecko_prod_api_key_here
COINGECKO_TIER=demo # demo | analyst | lite | pro | pro_plus
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_PRO_API_URL=https://pro-api.coingecko.com/api/v3
COINGECKO_WS_URL=wss://ws.coingecko.com/v1
# Rate limits: demo=30, analyst=500, pro=1000 (calls per minute)
COINGECKO_RATE_LIMIT_PER_MINUTE=30
COINGECKO_MAX_CONCURRENT_WS=10
COINGECKO_MAX_SUBSCRIPTIONS_PER_CHANNEL=100

# CoinMarketCap Configuration
# Development/Staging Key (Hobbyist - 30 requests/min)
COINMARKETCAP_API_KEY=your_coinmarketcap_dev_api_key_here
# Production Key (Commercial plan - 250-1000 requests/min)
COINMARKETCAP_API_KEY_PROD=your_coinmarketcap_prod_api_key_here
# Commercial license compliance
COINMARKETCAP_COMMERCIAL_LICENSE=false # Set to true for production/commercial use
COINMARKETCAP_API_URL=https://pro-api.coinmarketcap.com/v1
COINMARKETCAP_RATE_LIMIT_PER_MINUTE=30

# Database Configuration
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DATABASE=coinet
TIMESCALE_USER=coinet_user
TIMESCALE_PASSWORD=your_secure_password

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Service Configuration
NODE_ENV=development
LOG_LEVEL=info
CACHE_TTL_SECONDS=30
FAILOVER_RETRY_DELAY_MS=5000
MAX_RETRY_ATTEMPTS=3

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_REST_FALLBACK=true
ENABLE_CMC_FALLBACK=true

