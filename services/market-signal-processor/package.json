{
  "name": "@coinet/market-signal-processor",
  "version": "1.0.0",
  "description": "Divine world-class market signal processing service - ingests raw market signals, validates, enriches, and publishes to Kafka",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "docker:build": "docker build -t coinet-market-signal-processor .",
    "docker:run": "docker run -p 3000:3000 --env-file .env coinet-market-signal-processor"
  },
  "keywords": [
    "market-data",
    "kafka",
    "signal-processing",
    "rate-limiting",
    "observability",
    "typescript",
    "nodejs",
    "microservice",
    "serverless"
  ],
  "author": "Coinet Platform",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^20.0.0",
    "@types/winston": "^2.4.4",
    "async-retry": "^1.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "fast-json-patch": "^3.1.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "kafkajs": "^2.2.0",
    "lodash": "^4.17.0",
    "p-limit": "^4.0.0",
    "prometheus-api-metrics": "^3.2.0",
    "redis": "^4.6.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.5.0",
    "nodemon": "^2.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coinet-platform/market-signal-processor"
  },
  "bugs": {
    "url": "https://github.com/coinet-platform/market-signal-processor/issues"
  },
  "homepage": "https://github.com/coinet-platform/market-signal-processor#readme"
}
