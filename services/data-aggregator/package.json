{
  "name": "@coinet/data-aggregator",
  "version": "1.0.0",
  "description": "Production data aggregator service for real-time crypto data",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.production.json",
    "build:dev": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker build -f Dockerfile.production -t coinet/data-aggregator:v1.0.0 .",
    "docker:run": "docker run --rm -p 8004:8004 --name data-aggregator coinet/data-aggregator:v1.0.0",
    "clean": "rm -rf dist coverage .tsbuildinfo"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "axios": "^1.6.0",
    "p-limit": "^4.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "20.19.17",
    "typescript": "^5.5.0",
    "tsx": "^4.6.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "prettier": "^3.1.0"
  }
}
