{
  "name": "@coinet/api-gateway",
  "version": "1.0.0",
  "description": "Enterprise-grade API Gateway for Coinet platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "tsc-alias || true",
    "build:dev": "tsc",
    "start": "node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "docker:build": "docker build -f Dockerfile.production -t coinet/api-gateway:v1.0.0 .",
    "docker:run": "docker run --rm -p 8000:8000 --name api-gateway coinet/api-gateway:v1.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.11.0",
    "@sentry/profiling-node": "^10.11.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "argon2": "^0.31.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^4.7.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "20.19.17",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "coinet",
    "api-gateway",
    "microservices",
    "routing",
    "load-balancer",
    "circuit-breaker",
    "rate-limiting",
    "authentication",
    "monitoring"
  ],
  "author": "Coinet Engineering Team",
  "license": "MIT"
}
