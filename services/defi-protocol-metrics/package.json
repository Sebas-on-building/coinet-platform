{
  "name": "defi-protocol-metrics",
  "version": "1.0.0",
  "description": "DeFi protocol metrics monitoring service for Coinet platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "demo": "ts-node demo.ts",
    "demo:defi": "ts-node -r dotenv/config demo.ts"
  },
  "keywords": [
    "defi",
    "protocol",
    "metrics",
    "tvl",
    "yields",
    "lending",
    "liquidity",
    "governance",
    "token-unlocks",
    "anomaly-detection",
    "coinet"
  ],
  "author": "Coinet",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "ioredis": "^5.3.2",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "web3": "^4.1.2",
    "ethers": "^6.8.1",
    "@types/node": "^20.8.0",
    "cheerio": "^1.0.0-rc.12",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/node-cache": "^4.2.5",
    "@types/node-cron": "^3.0.11",
    "@types/web3": "^1.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
