{
  "name": "@coinet/alchemy-whales",
  "version": "2.0.0",
  "description": "Enterprise-grade on-chain whales & transfers monitoring using Alchemy + QuickNode (70+ chains) - World-class multi-provider integration with intelligent routing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "example:quicknode": "npx ts-node examples/quicknode-usage.ts",
    "example:ml-fraud": "npx ts-node examples/ml-fraud-detection.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts || true",
    "lint:fix": "eslint src/**/*.ts --fix || true",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "postinstall": "npm run build || true"
  },
  "keywords": [
    "alchemy",
    "quicknode",
    "multi-provider",
    "blockchain",
    "whales",
    "transfers",
    "ethereum",
    "polygon",
    "arbitrum",
    "optimism",
    "base",
    "70-chains",
    "multi-chain",
    "cross-validation",
    "on-chain",
    "monitoring",
    "analytics",
    "defi",
    "webhooks",
    "real-time",
    "nft",
    "token-api"
  ],
  "author": "Coinet",
  "license": "MIT",
  "dependencies": {
    "alchemy-sdk": "^3.3.0",
    "axios": "^1.6.2",
    "axios-retry": "^4.0.0",
    "bottleneck": "^2.19.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

