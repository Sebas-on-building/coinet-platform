# Add this to your ~/.bashrc or run in Codespace terminal:

# Alias to quickly navigate to alchemy-whales service
alias whales='cd /workspaces/coinet-platform/services/alchemy-whales'

# Alias to start the service
alias start-whales='cd /workspaces/coinet-platform/services/alchemy-whales && ./START_SERVICE.sh'

# Function to setup and start
whales-setup() {
    cd /workspaces/coinet-platform/services/alchemy-whales
    ./SETUP_DIRECTORY.sh
}

whales-start() {
    cd /workspaces/coinet-platform/services/alchemy-whales
    git pull origin feature/ai-data-feeder
    npx tsc -p tsconfig.json
    node dist/index.js
}

