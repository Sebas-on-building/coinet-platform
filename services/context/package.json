{
  "name": "@coinet/context-service",
  "version": "1.0.0",
  "description": "Coinet AI Context Assembler and Prompt Builder Service",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "docker:build": "docker build -f Dockerfile.production -t coinet/context-service:v1.0.0 .",
    "docker:run": "docker run --rm -p 8002:8002 --name context-service coinet/context-service:v1.0.0",
    "start:production": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "zod": "^3.22.4",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "20.19.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.8",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "context",
    "prompt",
    "crypto",
    "analysis",
    "intelligence",
    "coinet",
    "timescaledb",
    "postgresql",
    "kafka",
    "messaging",
    "realtime"
  ],
  "author": "Coinet Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coinet/coinet-platform.git",
    "directory": "services/context"
  }
}