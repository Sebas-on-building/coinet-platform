{
  "name": "@coinet/ai-service",
  "version": "1.0.0",
  "description": "🧠 Coinet AI Core Execution Engine - Transforms divine AI capabilities into structured crypto insights",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.production.json",
    "build:dev": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api": "npm run build && node dist/test-api.js",
    "test:brief": "npm run build && node dist/test-brief-generator.js",
    "test:input": "npm run build && node dist/test-input-processor.js",
    "ml:setup": "node dist/ml/setup-ml-environment.js",
    "ml:train": "node dist/ml/train-models.js",
    "ml:evaluate": "node dist/ml/evaluate-models.js",
    "ml:serve": "node dist/ml/serve-models.js",
    "ml:monitor": "node dist/ml/monitoring-dashboard.js",
    "ml:deploy": "node dist/ml/production-deployment.js",
    "ml:test": "node dist/ml/test-ml-infrastructure.js",
    "ml:pipeline": "npm run ml:setup && npm run ml:train && npm run ml:evaluate",
    "ml:full-pipeline": "npm run ml:test && npm run ml:deploy && npm run ml:monitor",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "server:start": "npm run build && npm start",
    "server:dev": "npm run dev",
    "docker:build": "docker build -f Dockerfile.production -t coinet/coinet-ai-service:v1.0.0 .",
    "docker:run": "docker run --rm -p 3001:3001 --name coinet-ai-service coinet/coinet-ai-service:v1.0.0",
    "start:production": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "@types/uuid": "^9.0.7",
    "node-cache": "^5.1.2",
    "async-retry": "^1.3.3",
    "openai": "^4.24.0",
    "@google/generative-ai": "^0.1.3",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-node": "^4.15.0",
    "@xenova/transformers": "^2.8.0",
    "onnxruntime-node": "^1.16.1",
    "ml-matrix": "^6.11.0",
    "ml-regression": "^6.0.1",
    "d3-array": "^3.2.4",
    "lodash": "^4.17.21",
    "mathjs": "^11.11.0",
    "papaparse": "^5.4.1",
    "csv-parser": "^3.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "20.19.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/async-retry": "^1.4.8",
    "@types/lodash": "^4.14.202",
    "@types/papaparse": "^5.3.14",
    "@types/d3-array": "^3.2.2",
    "typescript": "^5.5.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1"
  },
  "keywords": [
    "coinet",
    "ai",
    "crypto",
    "analysis",
    "execution-engine",
    "divine-perfection"
  ],
  "author": "Coinet AI Team",
  "license": "MIT"
}
