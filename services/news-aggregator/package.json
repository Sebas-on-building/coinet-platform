{
  "name": "news-aggregator",
  "version": "1.0.0",
  "description": "Real-time news aggregation and analysis service for Coinet platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "demo": "ts-node demo.ts",
    "demo:news": "ts-node -r dotenv/config demo.ts"
  },
  "keywords": [
    "news",
    "aggregation",
    "rss",
    "api",
    "websocket",
    "nlp",
    "classification",
    "coindesk",
    "cointelegraph",
    "reuters",
    "crypto",
    "blockchain",
    "coinet"
  ],
  "author": "Coinet",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "rss-parser": "^3.13.0",
    "ws": "^8.14.2",
    "natural": "^6.5.0",
    "compromise": "^14.10.0",
    "node-nlp": "^4.27.0",
    "ioredis": "^5.3.2",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "@types/node": "^20.8.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/node-cache": "^4.2.5",
    "@types/cheerio": "^0.22.35",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
