{
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "express": "^5.1.0",
    "graphql-playground-middleware": "^1.1.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/graphql": "^14.2.3",
    "@types/js-yaml": "^4.0.9",
    "graphql": "^16.11.0",
    "graphql-schema-linter": "^3.0.1",
    "js-yaml": "^4.1.0",
    "prisma": "^6.8.2",
    "yaml-lint": "^1.7.0",
    "typescript": "^5.5.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1"
  },
  "scripts": {
    "dev": "ts-node src/api/index.ts",
    "start": "node dist/api/index.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "docs:openapi": "npx yaml-lint src/docs/openapi.yaml",
    "docs:graphql": "npx graphql-schema-linter src/docs/graphql-schema.graphql",
    "docs": "npm run docs:openapi && npm run docs:graphql",
    "docs:serve": "ts-node src/api/index.ts"
  }
}