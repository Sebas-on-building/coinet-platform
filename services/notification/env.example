# Email Service Configuration

# Server Configuration
NODE_ENV=development
PORT=4005
LOG_LEVEL=info

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/notification-service

# Redis Configuration (for caching and queues)
REDIS_URL=redis://localhost:6379

# Email Provider Configuration

# AWS SES Configuration
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-secret-access-key

# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_WEBHOOK_SECRET=your-webhook-secret

# Default Email Configuration
DEFAULT_FROM_EMAIL=noreply@coinet.com

# Compliance Configuration
UNSUBSCRIBE_BASE_URL=https://coinet.com/unsubscribe
TRACKING_BASE_URL=https://coinet.com/track
TRACKING_DOMAIN=coinet.com

# Rate Limiting
MAX_EMAILS_PER_HOUR=10000
MAX_EMAILS_PER_DAY=100000
MAX_RECIPIENTS_PER_EMAIL=50

# Monitoring
MONITORING_ENABLED=true
METRICS_INTERVAL_SECONDS=300

# Security
JWT_SECRET=your-jwt-secret-for-authentication

# SMS Provider Configuration

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_STATUS_WEBHOOK_URL=https://your-domain.com/sms/webhooks/status

# Nexmo (Vonage) Configuration
NEXMO_API_KEY=your_nexmo_api_key
NEXMO_API_SECRET=your_nexmo_api_secret
NEXMO_PHONE_NUMBER=your_nexmo_phone_number
NEXMO_STATUS_WEBHOOK_URL=https://your-domain.com/sms/webhooks/status

# SMS Rate Limiting
MAX_SMS_PER_HOUR=1000
MAX_SMS_PER_DAY=5000
MAX_SMS_PER_DESTINATION_HOUR=10

# SMS Fallback Configuration
SMS_FALLBACK_ENABLED=true
SMS_FALLBACK_TIMEOUT_MS=300000

# Webhook Configuration
WEBHOOK_MASTER_SECRET=your-webhook-master-secret
WEBHOOK_DELIVERY_TIMEOUT_MS=30000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_CLEANUP_INTERVAL_HOURS=24

# Logging
LOG_LEVEL=info

# Bot Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-discord-channel-id-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

