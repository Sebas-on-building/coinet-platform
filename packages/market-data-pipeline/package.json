{
  "name": "@coinet/market-data-pipeline",
  "version": "1.0.0",
  "description": "Divine Steve Jobs Perfection Market Data Pipeline - Real-time, sub-10ms latency",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker build -t coinet-market-pipeline .",
    "docker:run": "docker run -p 3000:3000 coinet-market-pipeline",
    "k8s:deploy": "kubectl apply -f k8s/",
    "benchmark": "node dist/benchmark.js"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "axios": "^1.4.0",
    "bottleneck": "^2.19.5",
    "circuit-breaker-js": "^0.0.1",
    "influxdb-client": "0.0.1",
    "kafkajs": "^2.2.4",
    "ml-matrix": "^6.10.4",
    "ml-pca": "^4.0.2",
    "ml-regression": "^6.0.1",
    "node-cron": "^3.0.2",
    "opentelemetry": "^0.1.0",
    "p-limit": "^4.0.0",
    "prometheus-api-metrics": "^3.2.2",
    "redis": "^4.6.7",
    "winston": "^3.9.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "20.19.17",
    "@types/node-cron": "^3.0.8",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "jest": "^29.6.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "market-data",
    "real-time",
    "cryptocurrency",
    "trading",
    "kafka",
    "influxdb",
    "high-frequency",
    "low-latency",
    "microstructure",
    "orderbook",
    "tick-data"
  ],
  "author": "Coinet Engineering Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coinet/market-data-pipeline"
  }
