// Coinet Platform - Divine Database Schema
// Production-ready, optimized, and scalable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CONVERSATIONS & MESSAGES
// ============================================================================

model Conversation {
  id     String @id @default(cuid())
  userId String

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Conversation metadata
  title   String? // Auto-generated from first message
  context Json? // Conversation context, preferences, active agent

  // Relationships
  messages Message[]

  // Agent relationship (optional - if conversation uses a specific agent)
  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  // Indexes for performance
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String @id @default(cuid())
  conversationId String

  // Message content
  role    MessageRole
  content String      @db.Text

  // AI enhancements
  sources    Json? // Array of source citations
  charts     Json? // Chart configurations detected
  confidence Float? // AI confidence score (0-1)

  // Message metadata
  tokens Int? // Token count for cost tracking
  model  String? // AI model used (e.g., "gpt-4", "claude-3")

  // User actions
  regeneratedFrom String? // If regenerated, reference to original message
  userFeedback    MessageFeedback?

  // Timestamps
  createdAt DateTime @default(now())

  // Relationships
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([conversationId, createdAt(sort: Asc)])
  @@index([conversationId])
  @@map("messages")
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageFeedback {
  positive
  negative
  neutral
}

// ============================================================================
// AGENTS
// ============================================================================

model Agent {
  id     String @id @default(cuid())
  userId String

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic info
  name         String
  description  String @db.Text
  personality  String @db.Text
  systemPrompt String @db.Text

  // Agent configuration
  expertise   String[] // Array of expertise areas
  triggers    Json // Array of trigger configurations
  strategies  Json // Array of strategy configurations
  dataSources Json // Array of data source configurations

  // Appearance
  color String   @default("#6366f1") // Hex color
  tags  String[]

  // Agent status
  enabled    Boolean @default(true)
  isTemplate Boolean @default(false) // If from template/marketplace

  // Performance tracking
  totalExecutions Int   @default(0)
  successRate     Float @default(0.0) // 0-1

  // Relationships
  conversations Conversation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([userId, enabled])
  @@index([isTemplate])
  @@map("agents")
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id     String @id @default(cuid())
  userId String

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Alert info
  name        String
  description String?   @db.Text
  type        AlertType

  // Trigger configuration (parsed from natural language)
  trigger Json // Trigger configuration
  actions Json? // Alert actions (notifications, webhooks, etc.)

  // Alert settings
  priority AlertPriority @default(medium)
  enabled  Boolean       @default(true)

  // Execution tracking
  lastTriggered DateTime?
  triggerCount  Int       @default(0)

  // Relationships
  history AlertHistory[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([userId, enabled])
  @@index([type])
  @@index([enabled, priority])
  @@map("alerts")
}

enum AlertType {
  price
  technical
  sentiment
  volume
  onchain
  news
  custom
}

enum AlertPriority {
  low
  medium
  high
  critical
}

model AlertHistory {
  id      String @id @default(cuid())
  alertId String

  // Trigger data
  triggeredAt DateTime @default(now())
  conditions  Json // Condition values at trigger time
  values      Json // Actual values when triggered

  // Result
  executed Boolean @default(true)
  error    String? @db.Text

  // Relationships
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([alertId, triggeredAt(sort: Desc)])
  @@index([alertId])
  @@map("alert_history")
}

// ============================================================================
// INSIGHTS
// ============================================================================

model Insight {
  id String @id @default(cuid())

  // Insight content
  type        InsightType
  title       String
  description String      @db.Text

  // Quality metrics
  confidence Float // 0-1 confidence score
  severity   InsightSeverity

  // Rich metadata
  metadata Json // Type-specific data (asset, price, etc.)

  // Related assets
  assets String[] // Array of related asset symbols

  // Expiry
  expiresAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  // Indexes
  @@index([type])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("insights")
}

enum InsightType {
  sentiment
  catalyst
  risk
  opportunity
  pattern
  market_indicator
}

enum InsightSeverity {
  low
  medium
  high
  critical
}

// ============================================================================
// AUTHENTICATION & USER MANAGEMENT
// ============================================================================

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String // Hashed password
  name     String?

  // User roles and tiers
  role UserRole @default(USER)
  tier UserTier @default(FREE)

  // Account status
  active Boolean @default(true)
  avatar String?

  // Authentication tracking
  lastLoginAt DateTime?

  // Relationships
  preferences   UserPreferences?
  memories      UserMemory[]
  portfolio     UserPortfolio[]
  watchlist     UserWatchlist[]
  conversations Conversation[]
  agents        Agent[]
  alerts        Alert[]
  sessions      Session[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([active])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserTier {
  FREE
  PRO
  ENTERPRISE
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String   @default("default")
  token     String   @unique
  expiresAt DateTime
  isActive  Boolean  @default(true)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([isActive])
  @@map("sessions")
}

// ============================================================================
// USER PREFERENCES & SETTINGS
// ============================================================================

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Chat preferences
  defaultAgentId String?
  chatStyle      String? // "professional", "friendly", "technical"

  // Alert preferences
  alertEmail    Boolean @default(true)
  alertPush     Boolean @default(true)
  alertTimezone String  @default("UTC")

  // UI preferences
  theme    String @default("light")
  language String @default("en")

  // Trading preferences (for agent context)
  preferredAssets String[]
  riskTolerance   String? // "conservative", "moderate", "aggressive"

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ============================================================================
// USER MEMORY SYSTEM - Phase 3 Divine Integration
// ============================================================================

// Long-term memories the AI remembers about the user
model UserMemory {
  id     String @id @default(cuid())
  userId String

  // Memory content
  category MemoryCategory
  key      String // e.g., "favorite_coin", "trading_style"
  value    String         @db.Text // The actual memory content

  // Memory metadata
  confidence Float   @default(1.0) // How confident AI is about this memory
  source     String? // Where this memory came from (conversation, explicit)

  // Memory lifecycle
  lastAccessed DateTime @default(now())
  accessCount  Int      @default(0)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? // Some memories can expire
  User      User      @relation(fields: [userId], references: [id])

  // Indexes
  @@unique([userId, category, key])
  @@index([userId])
  @@index([userId, category])
  @@map("user_memories")
}

enum MemoryCategory {
  preference // User preferences (risk tolerance, style)
  portfolio // Holdings and positions
  watchlist // Coins they're watching
  goal // Trading/investment goals
  context // General context (experience level, location)
  interaction // How they like to interact
  insight // Things AI learned about them
}

// User's portfolio holdings
model UserPortfolio {
  id     String @id @default(cuid())
  userId String

  // Asset info
  symbol String // e.g., "BTC", "ETH"
  name   String? // Full name

  // Position details
  amount  Float // Amount held
  avgCost Float? // Average cost basis

  // Position metadata
  exchange String? // Where held (binance, coinbase, wallet)
  wallet   String? // Wallet address if applicable

  // Tracking
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id])

  // Indexes
  @@unique([userId, symbol, exchange])
  @@index([userId])
  @@map("user_portfolio")
}

// User's watchlist
model UserWatchlist {
  id     String @id @default(cuid())
  userId String

  // Asset info
  symbol String
  name   String?

  // Watch details
  targetBuy  Float? // Target buy price
  targetSell Float? // Target sell price
  notes      String? @db.Text

  // Alerts
  alertEnabled Boolean @default(true)

  // Timestamps
  addedAt DateTime @default(now())
  User    User     @relation(fields: [userId], references: [id])

  // Indexes
  @@unique([userId, symbol])
  @@index([userId])
  @@map("user_watchlist")
}

model OmniScoreHistory {
  id String @id @default(uuid())

  // Project identification
  projectId String @db.VarChar(100)

  // Score data
  pos       Float // Final POS after adjustments
  posRaw    Float? // POS before smoothing
  qsScore   Float? // Quality Score
  osScore   Float? // Opportunity Score
  riskScore Float? // Risk Score

  // Version tracking (critical for migrations)
  engineVersion  String @db.VarChar(20) // e.g., "2.5.0"
  formulaVersion String @db.VarChar(10) // e.g., "v2.5"

  // Context for debugging
  regime    String? @db.VarChar(20) // bull, bear, neutral, crisis, recovery
  capBucket String? @db.VarChar(20) // mega, large, mid, small, micro
  sector    String? @db.VarChar(30) // DeFi, L1, L2, etc.

  // Data quality metrics
  qsCoverage Float? // 0-1, percentage of valid QS inputs
  osCoverage Float? // 0-1, percentage of valid OS inputs
  degraded   Boolean @default(false) // Was this a degraded calculation?

  // Deduplication
  inputsHash String? @db.VarChar(64) // SHA256 of inputs for detecting identical runs

  // Timestamps
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  calculatedAt DateTime @default(now()) @db.Timestamp(6) // When the score was calculated

  // Indexes for efficient querying
  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, engineVersion, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("omniscore_history")
}

// ============================================================================
// PROJECT KNOWLEDGE BASE - Self-Improving Research System
// ============================================================================

model ProjectKnowledge {
  id        String @id @default(cuid())
  projectId String @unique @db.VarChar(100) // e.g., "uniswap", "bitcoin"

  // Basic identification
  name    String?  @db.VarChar(200)
  symbol  String?  @db.VarChar(20)
  ticker  String?  @db.VarChar(20)
  aliases String[] // Alternative names/tickers

  // Project details (AI-researched)
  description String? @db.Text
  category    String? @db.VarChar(50) // L1, L2, DeFi, Infrastructure, etc.
  website     String? @db.VarChar(500)
  whitepaper  String? @db.VarChar(500)

  // Team information (web-researched)
  teamInfo     Json? // { founders: [], advisors: [], backers: [] }
  foundedDate  DateTime?
  headquarters String?   @db.VarChar(200)

  // Partnerships & Backing (critical for scoring)
  partnerships Json? // { exchanges: [], vcs: [], strategic: [] }
  backers      Json? // { tier1: [], tier2: [], tier3: [] }

  // Security & Audits (web-researched)
  audits        Json? // { auditor: string, date: string, url: string }[]
  securityScore Int? // 0-100
  bugBounty     Boolean? @default(false)
  bugBountyUrl  String?  @db.VarChar(500)

  // Governance (web-researched)
  governanceType String? @db.VarChar(50) // DAO, Multisig, Foundation, etc.
  governanceUrl  String? @db.VarChar(500)
  votingPlatform String? @db.VarChar(100) // Snapshot, Tally, etc.

  // Social presence (web-researched)
  socialLinks Json? // { twitter: url, discord: url, telegram: url, github: url }

  // Technical info (web-researched)
  blockchain        String?  @db.VarChar(100) // Which chain it's built on
  contractAddresses Json? // { ethereum: address, bsc: address, etc. }
  codeRepository    String?  @db.VarChar(500)
  isOpenSource      Boolean? @default(false)

  // Research metadata
  researchDepth    Int      @default(1) // How many times researched (increases each update)
  lastResearchType String?  @db.VarChar(50) // "initial", "update", "deep_dive"
  dataQuality      Float? // 0-1, confidence in the data
  sourcesUsed      String[] // URLs/sources used in research

  // Verification status
  verified   Boolean   @default(false) // Manually verified by team
  verifiedBy String?   @db.VarChar(100)
  verifiedAt DateTime?

  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastResearchedAt DateTime @default(now())

  // Research history
  researchLogs ProjectResearchLog[]

  @@index([projectId])
  @@index([category])
  @@index([lastResearchedAt(sort: Desc)])
  @@index([researchDepth])
  @@map("project_knowledge")
}

model ProjectResearchLog {
  id        String @id @default(cuid())
  projectId String @db.VarChar(100)

  // What was researched
  researchType String  @db.VarChar(50) // "team", "audits", "partnerships", "governance", "full"
  query        String? @db.Text // The search query used

  // What was found
  findings    Json // Raw data discovered
  sourcesUsed String[] // URLs of sources
  confidence  Float? // 0-1, confidence in findings

  // What changed
  fieldsUpdated String[] // Which fields were updated
  dataAdded     Boolean  @default(false) // Did we add new data?
  dataRefined   Boolean  @default(false) // Did we refine existing data?

  // Context
  triggeredBy String? @db.VarChar(50) // "user_query", "scheduled", "manual"
  userId      String? @db.VarChar(100) // If triggered by user

  // Timestamps
  createdAt DateTime @default(now())

  // Relationships
  project ProjectKnowledge @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([researchType])
  @@index([createdAt(sort: Desc)])
  @@map("project_research_logs")
}
