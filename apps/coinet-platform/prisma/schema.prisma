// =============================================================================
// COINET AI PLATFORM - UNIFIED DATABASE SCHEMA WITH ROW-LEVEL SECURITY
// =============================================================================
// This unified schema consolidates all service-specific schemas into a single,
// coherent database design that supports the entire Coinet platform with
// comprehensive row-level security (RLS) for multi-tenant isolation.
//
// ROW-LEVEL SECURITY (RLS) IMPLEMENTATION:
// - All tables have tenantId fields for tenant isolation
// - RLS policies enforce tenant-based access control
// - GUC variable 'app.current_tenant' propagates tenant context
// - Application roles do not have BYPASSRLS privilege
//
// Services supported:
// - User Management (authentication, profiles, 2FA, API keys)
// - Plugin Marketplace (plugins, reviews, analytics)
// - Portfolio Management (portfolios, holdings, transactions)
// - Trading & Alerts (strategies, alerts, notifications)
// - Analytics & Audit (events, logs, A/B tests)
// - OAuth & Authentication (refresh tokens, password resets)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CORE USER MANAGEMENT
// =============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String   @map("passwordHash")
  role      UserRole @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Enhanced User Management Fields
  tier                 UserTier  @default(FREE)
  isVerified           Boolean   @default(false)
  verifiedAt           DateTime?
  isTwoFactorEnabled   Boolean   @default(false)
  twoFASecret          String?
  twoFactorBackupCodes String[]

  // Account Security
  loginAttempts        Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  verificationToken    String?

  // Profile Information
  avatar   String?
  bio      String?
  timezone String  @default("UTC")
  language String  @default("en")

  // Flexible metadata for extensibility
  metadata Json?

  // =============================================================================
  // RELATIONSHIPS
  // =============================================================================

  // Authentication & Sessions
  sessions            Session[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  apiKeys             ApiKey[]
  oauthAccounts       OAuthAccount[]
  trustedDevices      TrustedDevice[]
  backupCodes         BackupCode[]

  // Plugin Ecosystem
  plugins   Plugin[]             @relation("PluginAuthor")
  reviews   Review[]             @relation("UserReviews")
  userRoles UserRoleAssignment[]

  // Portfolio & Trading
  portfolios Portfolio[]
  alerts     Alert[]
  strategies Strategy[]

  // Signal & Alert System
  alertTriggers     AlertTrigger[]
  alertPerformances AlertPerformance[]
  userFeedback      UserFeedback[]

  // AI Insights System
  aiInsights       AIInsight[]
  aiModelPredictions AIModelPrediction[]
  aiRecommendationImplementations AIRecommendationImplementation[]
  aiDashboardViews AIDashboardView[]

  // Notification System
  notificationLogs NotificationLog[]

  // Analytics & Notifications
  auditLogs           AuditLog[]
  analyticsEvents     AnalyticsEvent[]
  notificationPrefs   NotificationPreference[]
  notificationEvents  NotificationEvent[]
  onboardingSteps     OnboardingStep[]
  onboardingAnalytics OnboardingAnalytics[]
  badges              Badge[]
  abTests             ABTest[]

  // Referral System
  referralsGiven    Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referee")

  // GDPR Compliance & Privacy
  consents          UserConsent[]
  gdprRequests      GDPRRequest[]
  privacyAuditLogs  PrivacyAuditLog[]

  // Encryption at rest relations
  encryptedData     EncryptedUserData[]
  encryptionKeys    UserEncryptionKey[]
  encryptionAuditLog EncryptionAuditLog[]

  @@index([email])
  @@index([role])
  @@index([tier])
  @@index([active])
  @@map("users")
}

// =============================================================================
// AUTHENTICATION & SESSIONS
// =============================================================================

model Session {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  tenantId     String   @default("default") @db.VarChar(36) // Multi-tenant isolation
  token        String   @unique
  refreshToken String?
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([token])
  @@index([isActive])
  @@map("sessions")
}

model RefreshToken {
  token     String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenantId  String   @default("default") @db.VarChar(36) // Multi-tenant isolation
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  token     String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenantId  String    @default("default") @db.VarChar(36) // Multi-tenant isolation
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tenantId])
  @@map("password_reset_tokens")
}

model ApiKey {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  tenantId    String    @default("default") @db.VarChar(36) // Multi-tenant isolation
  name        String
  keyHash     String    @unique
  keyPreview  String
  permissions String[]
  scopes      String[]  @default([])
  isActive    Boolean   @default(true)
  lastUsed    DateTime?
  usageCount  Int       @default(0)
  rateLimit   Int       @default(1000) // requests per hour
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([keyHash])
  @@index([isActive])
  @@map("api_keys")
}

model OAuthAccount {
  id           String    @id @default(uuid())
  provider     String // google, github, twitter, etc.
  providerId   String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  tenantId     String    @default("default") @db.VarChar(36) // Multi-tenant isolation
  accessToken  String?
  refreshToken String?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
  @@index([tenantId])
  @@map("oauth_accounts")
}

model TrustedDevice {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenantId  String   @default("default") @db.VarChar(36) // Multi-tenant isolation
  deviceId  String
  name      String?
  userAgent String?
  ipAddress String?
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([tenantId])
  @@map("trusted_devices")
}

model BackupCode {
  id       String    @id @default(uuid())
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  tenantId String    @default("default") @db.VarChar(36) // Multi-tenant isolation
  code     String
  used     Boolean   @default(false)
  usedAt   DateTime?

  @@index([userId])
  @@index([tenantId])
  @@map("backup_codes")
}

// =============================================================================
// ROLE-BASED ACCESS CONTROL (RBAC)
// =============================================================================

model UserRoleAssignment {
  id       String    @id @default(uuid())
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  tenantId String    @default("default") @db.VarChar(36) // Multi-tenant isolation
  role     RoleModel @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId   String

  assignedAt DateTime  @default(now())
  assignedBy String?
  expiresAt  DateTime?

  @@unique([userId, roleId])
  @@index([tenantId])
  @@map("user_roles")
}

model RoleModel {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  permissions Permission[]
  users       UserRoleAssignment[]
  isSystem    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("roles")
}

model Permission {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  resource    String // e.g., "users", "plugins", "portfolios"
  action      String // e.g., "read", "write", "delete"
  roles       RoleModel[]

  @@unique([resource, action])
  @@map("permissions")
}

// =============================================================================
// PLUGIN MARKETPLACE ECOSYSTEM
// =============================================================================

model Plugin {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  author      User         @relation("PluginAuthor", fields: [authorId], references: [id])
  authorId    String
  tenantId    String       @default("default") @db.VarChar(36) // Multi-tenant isolation
  version     String
  status      PluginStatus @default(PENDING)
  approved    Boolean      @default(false)
  featured    Boolean      @default(false)

  // Plugin Details
  category  String?
  tags      String[]
  readme    String?
  changelog String?

  // Marketplace
  price     Decimal? @db.Decimal(10, 2)
  currency  String   @default("USD")
  downloads Int      @default(0)

  // Technical
  sourceUrl   String?
  docsUrl     String?
  homepageUrl String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  reviews   Review[]          @relation("PluginReviews")
  registry  PluginRegistry?
  auditLogs AuditLog[]
  analytics PluginAnalytics[]

  // Flexible metadata
  metadata Json?

  @@index([authorId])
  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([featured])
  @@map("plugins")
}

model PluginRegistry {
  id        String   @id @default(uuid())
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginId  String   @unique
  versions  Json // [{version, hash, uploadedAt, size}]
  current   String // current version
  manifest  Json? // plugin manifest
  updatedAt DateTime @updatedAt

  @@map("plugin_registry")
}

model Review {
  id        String       @id @default(uuid())
  plugin    Plugin       @relation("PluginReviews", fields: [pluginId], references: [id], onDelete: Cascade)
  pluginId  String
  author    User         @relation("UserReviews", fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  rating    Int          @db.SmallInt // 1-5 stars
  title     String?
  text      String
  status    ReviewStatus @default(PENDING)
  flagged   Boolean      @default(false)
  helpful   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Moderation
  moderatedBy String?
  moderatedAt DateTime?

  metadata Json?

  @@index([pluginId])
  @@index([authorId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

model PluginAnalytics {
  id        String   @id @default(uuid())
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginId  String
  event     String // download, install, uninstall, error
  userId    String?
  version   String?
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([pluginId])
  @@index([event])
  @@index([timestamp])
  @@map("plugin_analytics")
}

// =============================================================================
// PORTFOLIO & TRADING
// =============================================================================

model Portfolio {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isPublic    Boolean  @default(false)
  totalValue  Decimal? @db.Decimal(20, 8)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  holdings     PortfolioHolding[]
  transactions Transaction[]

  @@index([userId])
  @@index([isDefault])
  @@map("portfolios")
}

model PortfolioHolding {
  id           String    @id @default(uuid())
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId  String
  symbol       String // BTC, ETH, etc.
  quantity     Decimal   @db.Decimal(20, 8)
  avgCost      Decimal   @db.Decimal(20, 8)
  currentPrice Decimal?  @db.Decimal(20, 8)
  totalValue   Decimal?  @db.Decimal(20, 8)
  updatedAt    DateTime  @default(now())

  @@unique([portfolioId, symbol])
  @@index([symbol])
  @@map("portfolio_holdings")
}

model Transaction {
  id          String            @id @default(uuid())
  portfolio   Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
  symbol      String
  side        TransactionSide
  type        TransactionType   @default(MARKET)
  quantity    Decimal           @db.Decimal(20, 8)
  price       Decimal           @db.Decimal(20, 8)
  fee         Decimal?          @db.Decimal(20, 8)
  total       Decimal           @db.Decimal(20, 8)
  status      TransactionStatus @default(COMPLETED)
  exchange    String?
  orderId     String?
  executedAt  DateTime
  createdAt   DateTime          @default(now())

  // Additional metadata
  metadata Json?

  @@index([portfolioId])
  @@index([symbol])
  @@index([executedAt])
  @@map("transactions")
}

model Alert {
  id           String         @id @default(uuid())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  name         String
  symbol       String
  condition    AlertCondition
  operator     AlertOperator
  threshold    Decimal        @db.Decimal(20, 8)
  currentValue Decimal?       @db.Decimal(20, 8)
  isActive     Boolean        @default(true)
  triggered    Boolean        @default(false)
  triggeredAt  DateTime?

  // Notification settings
  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(true)
  notifySMS   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notificationLogs  NotificationLog[]
  alertTriggers     AlertTrigger[]
  alertPerformances AlertPerformance[]
  userFeedback      UserFeedback[]

  @@index([userId])
  @@index([symbol])
  @@index([isActive])
  @@map("alerts")
}

model Strategy {
  id          String  @id @default(uuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  description String?
  definition  Json // Strategy logic/rules
  isActive    Boolean @default(false)
  isPublic    Boolean @default(false)

  // Performance metrics
  totalReturn Decimal? @db.Decimal(10, 4)
  winRate     Decimal? @db.Decimal(5, 4)
  sharpeRatio Decimal? @db.Decimal(10, 6)
  maxDrawdown Decimal? @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([isPublic])
  @@map("strategies")
}

// =============================================================================
// NOTIFICATIONS & ANALYTICS
// =============================================================================

model NotificationPreference {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  email      Boolean  @default(true)
  push       Boolean  @default(false)
  sms        Boolean  @default(false)
  inApp      Boolean  @default(true)
  categories String[] // alerts, portfolio, marketing, security

  @@unique([userId])
  @@map("notification_preferences")
}

model NotificationEvent {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String // alert_triggered, portfolio_update, etc.
  channel   String // email, push, sms, in_app
  title     String
  content   String
  data      Json?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  // A/B Testing
  abTestId String?
  abTest   ABTest? @relation(fields: [abTestId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
  @@map("notification_events")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  sessionId String?
  event     String // page_view, button_click, etc.
  category  String?
  action    String?
  label     String?
  value     Float?
  data      Json?
  timestamp DateTime @default(now())

  // Technical details
  userAgent String?
  ipAddress String?
  referer   String?

  @@index([userId])
  @@index([event])
  @@index([timestamp])
  @@map("analytics_events")
}

model AuditLog {
  id             String  @id @default(uuid())
  user           User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         String?
  plugin         Plugin? @relation(fields: [pluginId], references: [id], onDelete: SetNull)
  pluginId       String?
  signalSourceId String?

  // Enhanced audit fields for compliance
  timestamp      DateTime        @default(now()) @db.Timestamp(6)
  tenantId       String?         @db.VarChar(36) // For tenant isolation
  sessionId      String?         @db.VarChar(255) // Session identifier
  category       AuditLogCategory @default(DATA_ACCESS)

  action         String          @db.VarChar(100) // login, logout, create_plugin, etc.
  resource       String?         @db.VarChar(100) // users, plugins, portfolios
  resourceId     String?         @db.VarChar(36)
  details        String          @db.Text
  ipAddress      String?         @db.VarChar(45)
  userAgent      String?         @db.VarChar(500)

  // Data change tracking for compliance
  oldValues      Json?           // Previous values (for updates/deletes)
  newValues      Json?           // New values (for inserts/updates)
  outcome        String          @db.VarChar(50) @default("SUCCESS") // "SUCCESS", "FAILURE", "ERROR"
  errorMessage   String?         @db.Text

  // Security & Compliance
  signature      String          @db.VarChar(64) // cryptographic signature for tamper-proofing
  severity       LogSeverity     @default(INFO)
  complianceFlags Json?          // Compliance-specific flags (GDPR, SOX, etc.)

  // Retention and archiving
  retentionPeriod Int?           // Days to retain (null = use default)
  archived       Boolean         @default(false)
  archiveReason  String?         @db.Text

  // Immutability chain
  hash           String?         @db.VarChar(64) // Hash for tamper detection
  previousHash   String?         @db.VarChar(64) // Chain hash for immutability

  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @updatedAt @db.Timestamp(6)
  metadata       Json?
  SignalSource   SignalSource?   @relation(fields: [signalSourceId], references: [id])

  // Enhanced indexes for performance and compliance queries
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([category, severity, createdAt])
  @@index([action, createdAt])
  @@index([resource, resourceId])
  @@index([ipAddress, createdAt])
  @@index([sessionId, createdAt])
  @@index([archived, createdAt])
  @@index([outcome, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// ONBOARDING & GAMIFICATION
// =============================================================================

model OnboardingStep {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  step      String // verify_email, create_portfolio, etc.
  completed Boolean  @default(false)
  skipped   Boolean  @default(false)
  timestamp DateTime @default(now())
  data      Json?

  @@unique([userId, step])
  @@index([userId])
  @@map("onboarding_steps")
}

model OnboardingAnalytics {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  step       Int
  stepName   String
  completed  Boolean  @default(false)
  droppedOff Boolean  @default(false)
  timeSpent  Int? // seconds
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([step])
  @@map("onboarding_analytics")
}

model Badge {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  type        BadgeType
  icon        String
  description String?
  awardedAt   DateTime  @default(now())
  data        Json?

  @@index([userId])
  @@index([type])
  @@map("badges")
}

// =============================================================================
// A/B TESTING & EXPERIMENTS
// =============================================================================

model ABTest {
  id        String    @id @default(uuid())
  name      String
  variant   String
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)

  // Relations
  events NotificationEvent[]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([name])
  @@index([isActive])
  @@map("ab_tests")
}

// =============================================================================
// REFERRAL SYSTEM
// =============================================================================

model Referral {
  id         String  @id @default(uuid())
  referrer   User    @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId String
  referee    User?   @relation("Referee", fields: [refereeId], references: [id], onDelete: SetNull)
  refereeId  String?

  code         String         @unique
  status       ReferralStatus @default(PENDING)
  rewardGiven  Boolean        @default(false)
  rewardType   String?
  rewardAmount Decimal?       @db.Decimal(10, 2)

  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
  completedAt DateTime?

  @@index([referrerId])
  @@index([refereeId])
  @@index([code])
  @@map("referrals")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  MODERATOR
  USER
  AUTHOR
  DEVELOPER
  ANALYST
}

enum UserTier {
  FREE
  PREMIUM
  ENTERPRISE
  VIP
}

enum PluginStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
  SPAM
}

enum TransactionSide {
  BUY
  SELL
}

enum TransactionType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum AlertCondition {
  PRICE
  VOLUME
  MARKET_CAP
  CHANGE_24H
  RSI
  MACD
}

enum AlertOperator {
  GREATER_THAN
  LESS_THAN
  EQUAL_TO
  CROSSES_ABOVE
  CROSSES_BELOW
}

enum LogSeverity {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

enum BadgeType {
  ACHIEVEMENT
  MILESTONE
  SPECIAL
  SEASONAL
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  EXPIRED
  CANCELLED
}

// =============================================================================
// NOTIFICATION LOGS - ELITE HYPERSCALE NOTIFICATION SYSTEM
// =============================================================================
// WORLD-CLASS notification logging with advanced delivery optimization,
// intelligent retry strategies, real-time analytics, and enterprise-grade
// performance handling hundreds of billions of notifications per day.

enum NotificationChannel {
  PUSH // Mobile push notifications
  EMAIL // Email notifications
  SMS // SMS text messages
  WEBHOOK // HTTP webhook calls
  DISCORD // Discord bot messages
  TELEGRAM // Telegram bot messages
  IN_APP // In-app notifications
}

enum NotificationStatus {
  QUEUED // Notification queued for sending
  SENDING // Currently being sent
  SENT // Successfully sent to provider
  DELIVERED // Confirmed delivery to recipient
  FAILED // Failed to send (permanent failure)
  RETRY // Will be retried due to temporary failure
  CANCELLED // Cancelled before sending
}

enum NotificationPriority {
  LOW // Background notifications
  NORMAL // Standard priority
  HIGH // Important notifications
  URGENT // Critical alerts requiring immediate attention
}

model NotificationLog {
  // Primary identification
  id String @id @default(uuid()) @db.VarChar(36)

  // Core relationships
  alert   Alert?  @relation(fields: [alertId], references: [id], onDelete: SetNull)
  alertId String? @db.VarChar(36)
