// =============================================================================
// GDPR COMPLIANCE & PRIVACY MANAGEMENT
// =============================================================================
// Complete GDPR compliance system with consent management, data rights, and privacy controls

enum ConsentType {
  MARKETING_EMAILS     // Marketing and promotional emails
  ANALYTICS_TRACKING   // Website/app analytics tracking
  PERSONALIZATION     // Personalized content and recommendations
  DATA_PROCESSING     // General data processing consent
  THIRD_PARTY_SHARING // Sharing data with third parties
  PROFILING           // Automated decision-making and profiling
  NEWSLETTER          // Newsletter subscription
  PUSH_NOTIFICATIONS  // Push notification consent
  SMS_NOTIFICATIONS   // SMS notification consent
  TELEMETRY           // Usage statistics and telemetry
}

enum ConsentStatus {
  GRANTED     // Consent actively given
  DENIED      // Consent explicitly denied
  WITHDRAWN   // Consent withdrawn by user
  EXPIRED     // Consent expired (needs renewal)
  PENDING     // Consent pending (not yet given/denied)
}

enum DataRetentionPeriod {
  DAYS_30     // 30 days
  DAYS_90     // 90 days
  DAYS_180    // 180 days
  DAYS_365    // 1 year
  DAYS_730    // 2 years
  DAYS_1825   // 5 years
  DAYS_3650   // 10 years
  INDEFINITE  // No expiration
}

enum DataResidency {
  EU           // European Union
  US           // United States
  UK           // United Kingdom
  GLOBAL       // Global (any region)
  USER_CHOICE  // Follow user's residency
}

enum GDPRRequestType {
  ACCESS        // Article 15 - Right of access
  RECTIFICATION // Article 16 - Right to rectification
  ERASURE       // Article 17 - Right to erasure
  RESTRICTION   // Article 18 - Right to restriction of processing
  PORTABILITY   // Article 20 - Right to data portability
  OBJECTION     // Article 21 - Right to object
  AUTOMATED_DECISION // Article 22 - Automated individual decision-making
}

enum GDPRRequestStatus {
  PENDING     // Request submitted, not yet processed
  IN_REVIEW   // Request being reviewed by compliance team
  PROCESSING  // Request being processed
  COMPLETED   // Request completed successfully
  DENIED      // Request denied (with reason)
  CANCELLED   // Request cancelled by user
  EXPIRED     // Request expired (no response from user)
}

model UserConsent {
  id          String        @id @default(uuid()) @db.VarChar(36)
  userId      String        @db.VarChar(36)
  tenantId    String        @default("default") @db.VarChar(36)

  // Consent details
  consentType     ConsentType
  status          ConsentStatus @default(PENDING)
  version         String        @db.VarChar(20) // Version of consent text/terms
  consentText     String        @db.Text // Full consent text user agreed to

  // Timing
  grantedAt       DateTime?     @db.Timestamp(6)
  deniedAt        DateTime?     @db.Timestamp(6)
  withdrawnAt     DateTime?     @db.Timestamp(6)
  expiresAt       DateTime?     @db.Timestamp(6)

  // Collection method
  collectionMethod String       @db.VarChar(50) // "signup", "settings", "popup", "email"
  ipAddress        String?      @db.VarChar(45)
  userAgent        String?      @db.VarChar(500)

  // Withdrawal tracking
  withdrawalReason String?      @db.Text
  withdrawalMethod String?      @db.VarChar(50) // "settings", "email", "support"

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit trail
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @db.Timestamp(6)

  // Extensibility
  metadata        Json?

  @@unique([userId, consentType])
  @@index([userId, status])
  @@index([tenantId, consentType, status])
  @@index([status, expiresAt])
  @@index([collectionMethod, createdAt])
  @@map("user_consents")
}

model GDPRRequest {
  id          String           @id @default(uuid()) @db.VarChar(36)
  userId      String           @db.VarChar(36)
  tenantId    String           @default("default") @db.VarChar(36)

  // Request details
  requestType      GDPRRequestType
  status           GDPRRequestStatus @default(PENDING)
  priority         String           @db.VarChar(20) @default("NORMAL") // "LOW", "NORMAL", "HIGH", "URGENT"

  // Request content
  description      String           @db.Text // User's request description
  requestedData    String[]         // Specific data categories requested
  justification    String?          @db.Text // Legal basis or justification

  // Processing
  assignedTo       String?          @db.VarChar(36) // Staff member assigned
  estimatedCompletion DateTime?     @db.Timestamp(6)
  actualCompletion DateTime?       @db.Timestamp(6)

  // Response
  responseData     Json?            // Data provided in response
  responseFormat   String?          @db.VarChar(20) // "JSON", "CSV", "PDF"
  downloadUrl      String?          @db.VarChar(500) // Secure download link
  downloadExpires  DateTime?        @db.Timestamp(6)

  // Denial tracking (if applicable)
  denialReason     String?          @db.Text
  denialBasis      String?          @db.VarChar(100) // Legal basis for denial

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit trail
  createdAt        DateTime         @default(now()) @db.Timestamp(6)
  updatedAt        DateTime         @updatedAt @db.Timestamp(6)

  // Extensibility
  metadata         Json?

  @@index([userId, status])
  @@index([tenantId, requestType, status])
  @@index([status, createdAt])
  @@index([assignedTo, status])
  @@index([priority, status])
  @@map("gdpr_requests")
}

model DataRetentionPolicy {
