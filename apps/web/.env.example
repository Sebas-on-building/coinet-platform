# Coinet web (apps/web) environment.

# Clerk publishable key (client-safe, pk_...). MUST be from the SAME Clerk
# application as the backend's CLERK_SECRET_KEY, or tokens won't verify.
# Production instance (clerk.coinet.ai) pairs with the live api.coinet.ai backend.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Optional: explicit backend base URL (prod). Defaults to https://api.coinet.ai.
# In dev, leave unset to use the Vite proxy (see vite.config.ts).
# VITE_API_URL=https://api.coinet.ai

# Dev-only Vite proxy targets (see vite.config.ts):
# VITE_API_PROXY_TARGET=https://api.coinet.ai
# VITE_REGIME_PROXY=http://localhost:8080
